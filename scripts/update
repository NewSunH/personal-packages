#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

for command_name in curl jq nix; do
  if ! command -v "$command_name" >/dev/null 2>&1; then
    echo "required command not found: $command_name" >&2
    exit 1
  fi
done

api_headers=(
  -H "Accept: application/vnd.github+json"
  -H "X-GitHub-Api-Version: 2022-11-28"
)

if [[ -n "${GITHUB_TOKEN:-}" ]]; then
  api_headers+=(-H "Authorization: Bearer ${GITHUB_TOKEN}")
fi

github_get() {
  curl --silent --show-error --fail --location "${api_headers[@]}" "$1"
}

release_asset() {
  local release_json="$1"
  local asset_name="$2"

  jq --compact-output --exit-status --arg name "$asset_name" \
    '.assets[] | select(.name == $name)' <<<"$release_json"
}

flat_hash() {
  local asset_json="$1"
  local url digest

  url="$(jq --raw-output '.browser_download_url' <<<"$asset_json")"
  digest="$(jq --raw-output '.digest // ""' <<<"$asset_json")"

  if [[ "$digest" == sha256:* ]]; then
    nix hash convert --hash-algo sha256 --from base16 --to sri "${digest#sha256:}"
  else
    nix store prefetch-file --refresh --json "$url" | jq --raw-output --exit-status '.hash'
  fi
}

unpacked_hash() {
  local url="$1"

  nix store prefetch-file --refresh --unpack --json "$url" \
    | jq --raw-output --exit-status '.hash'
}

write_source() {
  local target="$1"
  local version="$2"
  local url="$3"
  local hash="$4"
  local temporary

  temporary="$(mktemp "${target}.XXXXXX")"
  jq --null-input \
    --arg version "$version" \
    --arg url "$url" \
    --arg hash "$hash" \
    '{ version: $version, url: $url, hash: $hash }' >"$temporary"
  mv "$temporary" "$target"
}

update_naiveproxy() {
  local release tag version asset_name asset url hash

  echo "Updating NaiveProxy metadata..."
  release="$(github_get "https://api.github.com/repos/klzgrad/naiveproxy/releases/latest")"
  tag="$(jq --raw-output --exit-status '.tag_name' <<<"$release")"
  version="${tag#v}"
  asset_name="naiveproxy-v${version}-linux-x64.tar.xz"
  asset="$(release_asset "$release" "$asset_name")"
  url="$(jq --raw-output --exit-status '.browser_download_url' <<<"$asset")"
  hash="$(flat_hash "$asset")"

  write_source packages/naiveproxy-bin/source.json "$version" "$url" "$hash"
}

update_ariang() {
  local release tag version asset_name asset url hash

  echo "Updating AriaNg metadata..."
  release="$(github_get "https://api.github.com/repos/mayswind/AriaNg/releases/latest")"
  tag="$(jq --raw-output --exit-status '.tag_name' <<<"$release")"
  version="${tag#v}"
  asset_name="AriaNg-${version}.zip"
  asset="$(release_asset "$release" "$asset_name")"
  url="$(jq --raw-output --exit-status '.browser_download_url' <<<"$asset")"
  hash="$(unpacked_hash "$url")"

  write_source packages/ariang/source.json "$version" "$url" "$hash"
}

update_rime_gram() {
  local release asset_name asset url hash

  echo "Updating Wanxiang LMDG metadata..."
  release="$(github_get "https://api.github.com/repos/amzxyz/RIME-LMDG/releases/tags/LTS")"
  asset_name="wanxiang-lts-zh-hans.gram"
  asset="$(release_asset "$release" "$asset_name")"
  url="$(jq --raw-output --exit-status '.browser_download_url' <<<"$asset")"
  hash="$(flat_hash "$asset")"

  write_source packages/rime-wanxiang-gram/source.json "LTS" "$url" "$hash"
}

update_rime_schema() {
  echo "Updating the rime-wanxiang-src flake input..."
  nix flake update rime-wanxiang-src
}

update_all() {
  update_naiveproxy
  update_ariang
  update_rime_gram
  update_rime_schema
}

if (( $# == 0 )); then
  set -- all
fi

for target in "$@"; do
  case "$target" in
    all)
      update_all
      ;;
    naiveproxy)
      update_naiveproxy
      ;;
    ariang)
      update_ariang
      ;;
    rime-gram)
      update_rime_gram
      ;;
    rime-schema)
      update_rime_schema
      ;;
    *)
      echo "unknown target: $target" >&2
      echo "expected one of: all, naiveproxy, ariang, rime-gram, rime-schema" >&2
      exit 2
      ;;
  esac
done

git diff --stat -- . ':(exclude)flake.lock' || true
git diff --stat -- flake.lock || true
